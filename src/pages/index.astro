---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FaultText from "../components/FaultText.astro";
import HotTags from "../components/HotTags.astro";
import PieChart from "../components/PieChart.astro";
import { countPostWords } from "../lib/wordCount";
import { siteConfig } from "../site.config";

const CAT_COLORS = [
  "#6B69D6", "#4ECDC4", "#FF6B6B", "#FFE66D",
  "#95E1D3", "#F38181", "#AA96DA", "#C0392B",
  "#45B7D1", "#96CEB4",
];

const posts = await getCollection("blog");

const dirWordCounts = new Map<string, number>();
for (const post of posts) {
  const parts = post.id.split("/");
  if (parts.length < 2) continue;
  const parentPath = parts.slice(0, -1).join("/");
  dirWordCounts.set(
    parentPath,
    (dirWordCounts.get(parentPath) || 0) + countPostWords(post)
  );
}
const hotTags = Array.from(dirWordCounts.entries())
  .map(([path, wc]) => ({
    name: path.split("/").pop()!,
    wordCount: wc,
    href: `/blog/${path}`,
  }))
  .sort((a, b) => b.wordCount - a.wordCount);

const catWordCounts = new Map<string, number>();
for (const post of posts) {
  const cat = post.id.split("/")[0];
  catWordCounts.set(
    cat,
    (catWordCounts.get(cat) || 0) + countPostWords(post)
  );
}
const pieData = Array.from(catWordCounts.entries())
  .map(([label, value], i) => ({
    label,
    value,
    color: CAT_COLORS[i % CAT_COLORS.length],
  }))
  .sort((a, b) => b.value - a.value);

const categoriesMap = new Map<string, number>();
for (const post of posts) {
  const cat = post.id.split("/")[0];
  if (cat) {
    categoriesMap.set(cat, (categoriesMap.get(cat) || 0) + 1);
  }
}
const categories = Array.from(categoriesMap.entries());
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <section class="py-12 text-center">
    {siteConfig.avatar && (
      <a href="/about"><img src={siteConfig.avatar} alt="avatar" class="_target mx-auto size-[150px] rounded-full" /></a>
    )}
    <div class="mt-4" style="--fault-text-size: 1.875rem; --fault-min-height: 3rem; --fault-text-weight: 700; --fault-letter-spacing: 0;">
      <FaultText text={siteConfig.title} />
    </div>
    <p class="mt-2 text-muted-foreground">{siteConfig.description}</p>
    {siteConfig.social && (
      <div class="mt-4 flex justify-center gap-4 text-sm text-muted">
        {Object.entries(siteConfig.social).map(([name, url]) => (
          <a href={url} class="_target text-muted-foreground hover:text-foreground transition-colors" target="_blank" rel="noopener noreferrer" title={name}>
            {name === "github" ? (
              <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37.0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44.0 0020 4.77 5.07 5.07.0 0019.91 1S18.73.65 16 2.48a13.38 13.38.0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07.0 005 4.77 5.44 5.44.0 003.5 8.55c0 5.42 3.3 6.61 6.44 7A3.37 3.37.0 009 18.13V22"></path></svg>
            ) : (
              name
            )}
          </a>
        ))}
      </div>
    )}
  </section>

  {pieData.length > 0 && (
    <section class="mt-12">
      <h2 class="text-xl font-semibold text-foreground">分布</h2>
      <div class="mt-4">
        <PieChart data={pieData} />
      </div>
    </section>
  )}

  {hotTags.length > 0 && (
    <section class="mt-12">
      <h2 class="text-xl font-semibold text-foreground">关键词</h2>
      <div class="mt-4">
        <HotTags items={hotTags} />
      </div>
    </section>
  )}

  <section class="mt-12">
    <a href="/blog" class="_target inline-block"><h2 class="text-xl font-semibold text-foreground hover:text-accent-link-hover transition-colors">分类</h2></a>
    <div class="mt-4 flex flex-wrap gap-3">
      {categories.map(([cat, count]) => (
        <a href={`/blog?category=${cat}`} class="_target rounded-full bg-secondary px-4 py-1.5 text-sm text-muted-foreground hover:bg-secondary-hover transition-colors">
          {cat} ({count})
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
