---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => {
    const slug = post.id.split("/").slice(1).join("/");
    return { params: { slug } };
  });
}

const { slug } = Astro.params;
const posts = await getCollection("blog");
const post = posts.find(
  (p) => p.id.split("/").slice(1).join("/") === slug
);

if (!post) {
  return Astro.redirect("/404");
}

const { Content } = await render(post);
const category = post.id.split("/")[0];
const formattedDate = post.data.date.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={post.data.title} description={post.data.title}>
  <article class="prose prose-gray max-w-none">
    <header class="mb-8 not-prose">
      <h1 class="text-3xl font-bold text-gray-900">{post.data.title}</h1>
      <div class="mt-3 flex items-center gap-3 text-sm text-gray-500">
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        {category && (
          <a href={`/categories/${category.toLowerCase()}`} class="text-blue-600 hover:underline">
            {category}
          </a>
        )}
      </div>
    </header>
    <Content />
  </article>
</BaseLayout>
