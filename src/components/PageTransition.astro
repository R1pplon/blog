---

<div id="page-transition">
  <svg viewBox="0 0 50 50">
    <circle r="25" cx="25" cy="25"></circle>
  </svg>
  <p>LOADING</p>
</div>

<style is:global>
  #page-transition {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: var(--pt-locked-bg, var(--color-secondary));
    z-index: 100000000;
    transition: transform 1s ease;
    will-change: transform;
  }

  #page-transition svg {
    width: 5rem;
    margin-bottom: 2rem;
    overflow: visible;
    transition: opacity 0.3s ease;
  }

  #page-transition svg circle {
    fill: none;
    stroke: var(--pt-locked-accent, var(--color-accent));
    stroke-width: 12;
    stroke-dasharray: 100;
    stroke-dashoffset: 0;
    transform-origin: center;
    animation: pt_circle_rotate 1s linear infinite;
    will-change: transform;
  }

  @keyframes pt_circle_rotate {
    to {
      transform: rotate(360deg);
    }
  }

  #page-transition p {
    font-family: sans-serif;
    font-size: 2rem;
    color: var(--pt-locked-accent, var(--color-accent));
    font-weight: 900;
    transition: opacity 0.3s ease;
  }

  #page-transition.pt_hidden svg,
  #page-transition.pt_hidden p {
    opacity: 0;
  }
</style>

<script is:inline>
  var pt = document.getElementById("page-transition");

  function ptShow() {
    pt.style.removeProperty("--pt-locked-bg");
    pt.style.removeProperty("--pt-locked-accent");
    var cs = getComputedStyle(pt);
    pt.style.setProperty("--pt-locked-bg", cs.getPropertyValue("--color-secondary"));
    pt.style.setProperty("--pt-locked-accent", cs.getPropertyValue("--color-accent"));

    pt.classList.remove("pt_hidden");
    pt.style.transition = "none";
    pt.style.transform = "translateY(100%)";
    pt.offsetHeight;
    pt.style.transition = "";
    pt.style.transform = "";
  }

  function ptHide() {
    pt.classList.add("pt_hidden");
    pt.style.transform = "translateY(-100%)";
    setTimeout(function () {
      pt.style.removeProperty("--pt-locked-bg");
      pt.style.removeProperty("--pt-locked-accent");
    }, 1000);
  }

  window.__pt = { show: ptShow, hide: ptHide };

  document.addEventListener("DOMContentLoaded", function () {
    requestAnimationFrame(function () {
      requestAnimationFrame(ptHide);
    });
  });

  document.addEventListener(
    "click",
    function (e) {
      var link = e.target.closest("a");
      if (!link) return;
      if (!link.href) return;
      if (link.target === "_blank") return;
      if (link.hostname !== location.hostname) return;
      if (link.protocol === "mailto:" || link.protocol === "javascript:") return;

      e.preventDefault();
      ptShow();
      setTimeout(function () {
        location.href = link.href;
      }, 1000);
    },
    { capture: true },
  );
</script>
