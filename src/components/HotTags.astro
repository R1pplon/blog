---
interface Props {
  items: { name: string; wordCount: number; href: string }[];
}

const { items } = Astro.props;
const sorted = items.sort((a, b) => b.wordCount - a.wordCount);
const maxWC = Math.max(1, ...sorted.map((i) => i.wordCount));
const minWC = Math.min(maxWC, ...sorted.map((i) => i.wordCount));
const range = maxWC - minWC || 1;
const MIN_FONT = 0.85;
const MAX_FONT = 1.4;
---

<div class="hot-tags">
  {sorted.map((item) => {
    const ratio = (item.wordCount - minWC) / range;
    const fontSize = MIN_FONT + ratio * (MAX_FONT - MIN_FONT);
    return (
      <a
        href={item.href}
        class="_target hot-tag-item"
        style={`font-size: ${fontSize}rem`}
        title={`${item.name}: ${item.wordCount}字`}
      >
        {item.name}:{item.wordCount}
      </a>
    );
  })}
</div>

<style>
  .hot-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: baseline;
  }
  .hot-tag-item {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    background-color: var(--color-secondary);
    color: var(--color-muted-foreground);
    transition: color 0.2s, background-color 0.2s;
    line-height: 1.4;
  }
  .hot-tag-item:hover {
    background-color: var(--color-secondary-hover);
    color: var(--color-foreground);
  }
</style>
