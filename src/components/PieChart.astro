---
interface DataItem {
  label: string;
  value: number;
  color: string;
}

interface Props {
  data: DataItem[];
}

const { data } = Astro.props;
const total = data.reduce((s, d) => s + d.value, 0) || 1;

const MAX_DISPLAY = 9;
const MIN_PCT = 0.02;

let visible = [...data];
let others: DataItem[] = [];

if (visible.length > MAX_DISPLAY) {
  others = visible.slice(MAX_DISPLAY);
  visible = visible.slice(0, MAX_DISPLAY);
}

visible = visible.filter((d) => {
  if (d.value / total < MIN_PCT) {
    others.push(d);
    return false;
  }
  return true;
});

if (others.length > 0) {
  const otherTotal = others.reduce((s, d) => s + d.value, 0);
  visible.push({ label: "其他", value: otherTotal, color: "#999999" });
}

const CX = 95;
const CY = 90;
const OUTER_R = 80;
const INNER_R = 40;

function polarX(r: number, angle: number) {
  return CX + r * Math.cos(angle - Math.PI / 2);
}
function polarY(r: number, angle: number) {
  return CY + r * Math.sin(angle - Math.PI / 2);
}

let cumulative = 0;

function arcPath(startAngle: number, endAngle: number) {
  const largeArc = endAngle - startAngle > Math.PI ? 1 : 0;
  const ox0 = polarX(OUTER_R, startAngle);
  const oy0 = polarY(OUTER_R, startAngle);
  const ox1 = polarX(OUTER_R, endAngle);
  const oy1 = polarY(OUTER_R, endAngle);
  const ix0 = polarX(INNER_R, endAngle);
  const iy0 = polarY(INNER_R, endAngle);
  const ix1 = polarX(INNER_R, startAngle);
  const iy1 = polarY(INNER_R, startAngle);

  return `M${ox0},${oy0} A${OUTER_R},${OUTER_R} 0 ${largeArc} 1 ${ox1},${oy1} L${ix0},${iy0} A${INNER_R},${INNER_R} 0 ${largeArc} 0 ${ix1},${iy1} Z`;
}
---

<div class="pie-chart">
  <svg viewBox="0 0 320 200" class="pie-svg">
    {visible.map((d) => {
      const pct = d.value / total;
      const angle = pct * 2 * Math.PI;
      const startAngle = cumulative;
      const endAngle = cumulative + angle;
      cumulative = endAngle;

      const midAngle = startAngle + angle / 2;
      const labelR = 65;
      const lx = CX + labelR * Math.cos(midAngle - Math.PI / 2);
      const ly = CY + labelR * Math.sin(midAngle - Math.PI / 2);

      return (
        <>
          <path d={arcPath(startAngle, endAngle)} fill={d.color} class="pie-slice _target" style={`cursor: pointer`} onclick={`location.href='/blog?category=${d.label}'`}>
            <title>{`${d.label}: ${d.value}字 (${Math.round(pct * 100)}%)`}</title>
          </path>
          {pct > 0.04 && (
            <text x={lx} y={ly} text-anchor="middle" dominant-baseline="central" class="pie-label">{d.label}</text>
          )}
        </>
      );
    })}
  </svg>
  <div class="pie-legend">
    {visible.map((d) => {
      const pct = Math.round((d.value / total) * 100);
      return (
        <div class="legend-item">
          <span class="legend-swatch" style={`background-color: ${d.color}`}></span>
          <span class="legend-label">{d.label}</span>
          <span class="legend-pct">{pct}%</span>
        </div>
      );
    })}
  </div>
</div>

<style>
  .pie-chart {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .pie-svg {
    width: 280px;
    height: auto;
    flex-shrink: 0;
  }
  .pie-slice {
    transition: opacity 0.2s;
  }
  .pie-slice:hover {
    opacity: 0.85;
  }
  .pie-label {
    font-size: 6px;
    fill: var(--color-surface, #faf9f6);
    pointer-events: none;
  }
  .pie-legend {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    font-size: 0.875rem;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .legend-swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .legend-label {
    color: var(--color-foreground);
  }
  .legend-pct {
    color: var(--color-muted-foreground);
    margin-left: auto;
  }
</style>
