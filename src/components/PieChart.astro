---
interface DataItem {
  label: string;
  value: number;
  color: string;
}

interface Props {
  data: DataItem[];
}

const { data } = Astro.props;
const total = data.reduce((s, d) => s + d.value, 0) || 1;

const MAX_DISPLAY = 9;
const MIN_PCT = 0.02;

let visible = [...data];
let others: DataItem[] = [];

if (visible.length > MAX_DISPLAY) {
  others = visible.slice(MAX_DISPLAY);
  visible = visible.slice(0, MAX_DISPLAY);
}

visible = visible.filter((d) => {
  if (d.value / total < MIN_PCT) {
    others.push(d);
    return false;
  }
  return true;
});

if (others.length > 0) {
  const otherTotal = others.reduce((s, d) => s + d.value, 0);
  visible.push({ label: "其他", value: otherTotal, color: "#999999" });
}

const chartData = visible.map((d) => ({
  name: d.label,
  value: d.value,
  itemStyle: { color: d.color },
}));
---

<div
  class="pie-chart-container _target"
  data-options={JSON.stringify(chartData)}
  style="width: 100%; height: 420px"
></div>

<script>
  import { initPieChart } from "../lib/chart";

  const container = document.querySelector(".pie-chart-container") as HTMLElement | null;
  if (container) {
    initPieChart(container);
  }
</script>
