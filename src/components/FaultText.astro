---
const { text = "404" } = Astro.props;
---

<div class="_target fault-container text-center py-8" data-text={text}>
  <p class="_target faulttext">{text}</p>
  <p class="_target faulttext">{text}</p>
  <p class="_target faulttext">{text}</p>
  <p class="_target faulttext">{text}</p>
</div>

<style>
  .fault-container {
    display: grid;
    place-items: center;
    min-height: 16rem;
    cursor: pointer;
    user-select: none;
  }
  .fault-container > * {
    grid-area: 1 / 1;
  }

  .faulttext {
    font-family: inherit;
    font-size: 8rem;
    font-weight: 900;
    letter-spacing: 0.5rem;
    line-height: 1;
    color: var(--color-foreground, #f3f4f6);
  }

  .faulttext.fault::after,
  .faulttext.fault::before {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    mix-blend-mode: screen;
  }

  .faulttext.fault::after {
    color: var(--color-accent, #6B69D6);
    transform: translateX(2%);
  }

  .faulttext.fault::before {
    color: #17f700;
    transform: translateX(-2%);
  }
</style>

<script is:inline>
  (function () {
    const container = document.currentScript.parentElement;
    const textEls = container.querySelectorAll(".faulttext");
    const text = container.dataset.text || "404";

    textEls.forEach((el) => {
      el.setAttribute("data-text", text);
    });

    let player = null;

    function glitch() {
      if (player) return;

      const stopTime = setTimeout(() => {
        clearInterval(player);
        player = null;
        textEls.forEach((el) => {
          el.classList.remove("fault");
          el.style.transform = "";
          el.style.clipPath = "";
        });
      }, 1000);

      player = setInterval(() => {
        textEls.forEach((el) => {
          el.classList.add("fault");
          el.style.transform = `translate(${Math.random() * 60 - 30}%,${Math.random() * 60 - 30}%)`;
          const x = Math.random() * 100;
          const y = Math.random() * 100;
          const h = Math.random() * 50 + 50;
          const w = Math.random() * 40 + 10;
          el.style.clipPath = `polygon(${x}% ${y}%, ${x + w}% ${y}%, ${x + w}% ${y + h}%, ${x}% ${y + h}%)`;
        });
      }, 30);
    }

    container.addEventListener("click", glitch);
  })();
</script>
