---
import { siteConfig } from "../site.config";
---

<header class="sticky top-0 z-10 border-b bg-white/80 backdrop-blur">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
    <a href="/" class="text-lg font-semibold text-gray-900">
      {siteConfig.title}
    </a>
    <ul class="flex gap-6 text-sm text-gray-600">
      {siteConfig.nav.map((item) => (
        <li>
          <a href={item.href} class="hover:text-gray-900 transition-colors">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
